# Enforce LF for shell scripts and Dockerfiles — CRLF breaks bash in containers
*.sh        text eol=lf
*.dockerfile text eol=lf
Dockerfile  text eol=lf
*.conf      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.xml       text eol=lf

# Binary files — no line ending conversion
*.jpg       binary
*.png       binary
*.gif       binary
*.ico       binary
*.gz        binary
*.tar       binary
*.zip       binary
